{
  "name": "meditrack",
  "version": "0.1.0",
  "description": "Medication management for modern healthcare workflows",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "cli": "tsx src/ui/cli/meditrack.ts",
    "server": "tsx src/ui/server/server.ts",
    "repos:spy": "tsx src/ui/events/repo-spy.ts"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@graphql-codegen/client-preset": "^4.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "prisma": "^6.19.3",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "bcryptjs": "^2.4.3",
    "jose": "^5.0.0",
    "@prisma/client": "^6.19.3",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "graphql": "^16.14.0",
    "graphql-ws": "^6.0.8",
    "graphql-yoga": "^5.21.0",
    "ws": "^8.21.0"
  }
}
